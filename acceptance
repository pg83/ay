#!/usr/bin/env python3
"""acceptance — semi-automatic merge gate for the overseer.

    ./acceptance <OLD_REPO> <NEW_REPO>

Runs <repo>/dev/validate.py in BOTH repos — each in its own writable out-dir
under $TMPDIR, so the repos themselves may be READ-ONLY — parses the per-case
metrics from each run, and decides whether NEW may be merged over OLD per the
PROMPTS.md gating rules:

  * gating `[<case>] OK` count must NOT drop (it may rise);
  * `XFAIL` count must NOT grow;
  * no NEW `FAIL` may appear (a case FAILing in NEW that did not FAIL in OLD);
  * each XFAIL case's normalized-node parity `matched=` must NOT decrease.

Only cases evaluated (non-SKIP) in BOTH repos are compared.

Each `./dev/validate.py` run is bounded to VALIDATE_TIMEOUT_S; if a run exceeds
it (e.g. an sg7 generation that wedges on the arc FUSE), the whole process tree
is killed and acceptance exits non-zero — a candidate that cannot even validate
in the budget is not mergeable.

exit 0 -> ACCEPT (mergeable);  exit 1 -> REJECT (or a validate.py run failed /
timed out);  exit 2 -> bad usage.
"""
import os
import re
import shutil
import signal
import subprocess
import sys
import tempfile
import threading
import time
import traceback
from dataclasses import dataclass

# validate.py only ever exits 0 (all gating byte-exact) or 1 (some gating
# failure). Any other code — or a signal-negative — means the validator itself
# crashed (launch error, uncaught exception, killed), not a candidate rejection.
VALIDATE_OK_EXITS = (0, 1)
# How many trailing output lines to echo when a side is unusable, so the merger
# log shows the crash context instead of a bare header.
DIAG_TAIL_LINES = 25

# One ./dev/validate.py run budget. The user-stated wall cost of a single run is
# ~10 minutes; over this we kill the run's whole process group and reject.
# Override via $ACCEPTANCE_TIMEOUT_S (seconds).
VALIDATE_TIMEOUT_S = int(os.environ.get("ACCEPTANCE_TIMEOUT_S", "2400"))

# validate.py exit 1 is overloaded: a normal gating rejection (it prints
# "[<case>] FAIL" lines and exits 1) AND an unhandled Python exception (the
# interpreter prints this marker line at column 0, then exits 1). validate.py
# never prints a traceback during normal operation, so this line distinguishes a
# validator crash (infrastructure failure → unusable) from a candidate rejection
# (policy applies). Without it, a run that emits a few OK cases then raises is
# silently ACCEPTed because decide() compares only the cases that survived.
TRACEBACK_LINE = re.compile(r"^Traceback \(most recent call last\):$", re.M)

# Status lines printed by validate.py, e.g. "[sg2] OK", "[sg7] FAIL (generate)",
# "[sg7] XFAIL (not gating) — …", "[sg5] SKIP (data not present …)".
CASE_LINE = re.compile(r"^\[(\w+)\]\s+(OK|FAIL|XFAIL|SKIP)\b")

# The xfail parity line:
# "[sg7] exact normalized-node parity: matched=N our_only=N ref_only=N our_total=N ref_total=N"
PARITY_LINE = re.compile(
    r"^\[(\w+)\]\s+exact normalized-node parity:\s+"
    r"matched=(\d+)\s+our_only=(\d+)\s+ref_only=(\d+)\s+our_total=(\d+)\s+ref_total=(\d+)"
)


_LOG_LOCK = threading.Lock()


def log(msg=""):
    # Line-atomic: OLD and NEW stream concurrently, so guard the print so their
    # prefixed lines never interleave mid-line.
    with _LOG_LOCK:
        print(msg, flush=True)


@dataclass
class RunResult:
    """Outcome of one `dev/validate.py` run.

    completed  — the run launched, streamed, and exited without timing out or
                 raising in the orchestrator (it may still have crashed: check
                 returncode). A False here always carries a non-empty `error`.
    returncode — validate.py's exit code (None if it never launched / was killed
                 before exit).
    output     — captured stdout (validate.py's stdout+stderr, streamed).
    error      — non-empty iff this side is UNUSABLE for comparison and the
                 string explains why (launch error, timeout, worker crash, …).
    """

    label: str
    completed: bool
    returncode: object = None
    output: str = ""
    error: str = ""


def run_validate(label, repo, out_dir):
    """Run <repo>/dev/validate.py out_dir, streaming its output live (prefixed)
    and capturing it. Returns a RunResult. A launch failure, timeout, or stream
    error is captured into RunResult.error (and logged to stdout) rather than
    raised — the orchestrator must never lose the reason to stderr."""
    validate = os.path.join(repo, "dev", "validate.py")

    if not os.path.isfile(validate):
        msg = f"missing {validate}"
        log(f"[acceptance] {label}: {msg}")

        return RunResult(label, False, error=msg)

    os.makedirs(out_dir, exist_ok=True)
    log(f"[acceptance] === {label}: {validate} {out_dir}  (timeout {VALIDATE_TIMEOUT_S}s) ===")

    t0 = time.monotonic()
    # start_new_session so the whole tree (validate.py + ay) shares a process
    # group we can kill on timeout; ay does not orphan if we only kill validate.
    try:
        proc = subprocess.Popen(
            [sys.executable, validate, out_dir],
            cwd=repo,
            text=True,
            bufsize=1,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            start_new_session=True,
        )
    except OSError as e:
        msg = f"failed to launch validate.py: {e!r}"
        log(f"[acceptance] {label}: {msg}")

        return RunResult(label, False, error=msg)

    timed_out = {"v": False}

    def killer():
        timed_out["v"] = True

        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass

    watchdog = threading.Timer(VALIDATE_TIMEOUT_S, killer)
    watchdog.start()

    lines = []
    # A read/wait failure on the pipe must not escape to stderr, AND it must not
    # be silently swallowed: a transcript truncated by a stream failure is
    # UNUSABLE even when the lines parsed so far look fine and the child would
    # have exited 0/1. Capture the reason so this side becomes a recorded error.
    stream_error = None

    try:
        for ln in proc.stdout:
            lines.append(ln)
            log(f"  [{label}] {ln.rstrip()}")
    except Exception as e:
        stream_error = f"reading validate.py stdout failed after {len(lines)} line(s): {e!r}"
        lines.append(f"<stream error: {e!r}>\n")
        log(f"[acceptance] {label}: {stream_error}")
    finally:
        try:
            proc.wait()
        except Exception as e:
            if stream_error is None:
                stream_error = f"waiting for validate.py failed: {e!r}"
                lines.append(f"<wait error: {e!r}>\n")
                log(f"[acceptance] {label}: {stream_error}")
        watchdog.cancel()

    dt = time.monotonic() - t0
    output = "".join(lines)

    if timed_out["v"]:
        msg = f"TIMEOUT after {VALIDATE_TIMEOUT_S}s — killed; not mergeable"
        log(f"[acceptance] {label}: {msg}")

        return RunResult(label, False, returncode=proc.returncode, output=output, error=msg)

    if stream_error is not None:
        # The transcript is truncated/unreliable; reject this side regardless of
        # the child's return code or how many case lines parsed before the fault.
        return RunResult(label, False, returncode=proc.returncode, output=output, error=stream_error)

    log(f"[acceptance] {label}: validate.py exit={proc.returncode} in {dt:.1f}s")

    return RunResult(label, True, returncode=proc.returncode, output=output)


def parse(output):
    """Parse validate.py output. Returns (status, matched, onlies):
    status[case] -> 'OK'|'FAIL'|'XFAIL'|'SKIP' (last status line per case wins),
    matched[case] -> int parity matched, onlies[case] -> (our_only, ref_only)."""
    status, matched, onlies = {}, {}, {}

    for ln in output.splitlines():
        m = CASE_LINE.match(ln)

        if m:
            status[m.group(1)] = m.group(2)

            continue

        m = PARITY_LINE.match(ln)

        if m:
            case = m.group(1)
            matched[case] = int(m.group(2))
            onlies[case] = (int(m.group(3)), int(m.group(4)))

    return status, matched, onlies


def _tail(output, n=DIAG_TAIL_LINES):
    lines = output.splitlines()
    shown = lines[-n:]
    body = "\n".join(f"    | {ln}" for ln in shown) if shown else "    | (no output captured)"
    elided = "" if len(lines) <= n else f"    | … ({len(lines) - n} earlier line(s) elided)\n"
    return elided + body


def usability_reason(res, status):
    """Return a non-empty reason iff this side cannot be compared: a launch
    error, timeout, worker crash, a validate.py crash (exit not in {0,1} or
    killed), or a run that produced no parseable case line at all (crashed
    before emitting any case). Empty string => usable; parse + policy apply.

    A clean all-SKIP run (exit 0, SKIP lines present) stays usable, preserving
    the existing 'no data on host' ACCEPT behavior."""
    if res.error:
        return res.error
    if res.returncode is None:
        return "validate.py never reported an exit code"
    if res.returncode not in VALIDATE_OK_EXITS:
        return f"validate.py crashed (exit={res.returncode}); not a candidate rejection"
    if res.returncode != 0 and TRACEBACK_LINE.search(res.output):
        return (
            f"validate.py raised an unhandled exception (exit={res.returncode}; "
            f"Python traceback in output) — validator crash, not a candidate rejection"
        )
    if not status:
        return (
            f"validate.py exited {res.returncode} but produced no case results "
            f"(no [<case>] OK/FAIL/XFAIL/SKIP line) — validator failure, not a candidate rejection"
        )
    return ""


def decide(so, mo, oo, sn, mn, on):
    """Compare OLD (so/mo/oo) vs NEW (sn/mn/on). Returns (accept, reasons[])."""
    # Compare only cases evaluated (present, non-SKIP) in BOTH repos.
    common = sorted(c for c in so if c in sn and so[c] != "SKIP" and sn[c] != "SKIP")

    log("")
    log("[acceptance] ===== per-case  OLD -> NEW =====")

    for case in sorted(set(so) | set(sn)):
        old, new = so.get(case, "—"), sn.get(case, "—")
        parity = ""

        if case in mo or case in mn:
            po = f"{mo.get(case, '—')}/{oo.get(case, ('—', '—'))}"
            pn = f"{mn.get(case, '—')}/{on.get(case, ('—', '—'))}"
            parity = f"   parity matched/(our_only,ref_only) {po} -> {pn}"

        excluded = "" if case in common else "   (SKIP — excluded)"
        log(f"  {case:14} {old:6} -> {new:6}{parity}{excluded}")

    ok_old = sum(1 for c in common if so[c] == "OK")
    ok_new = sum(1 for c in common if sn[c] == "OK")
    xf_old = sum(1 for c in common if so[c] == "XFAIL")
    xf_new = sum(1 for c in common if sn[c] == "XFAIL")
    fail_old = sum(1 for c in common if so[c] == "FAIL")
    fail_new = sum(1 for c in common if sn[c] == "FAIL")

    log("")
    log(f"[acceptance] OK     {ok_old} -> {ok_new}    (must not drop)")
    log(f"[acceptance] XFAIL  {xf_old} -> {xf_new}    (must not grow)")
    log(f"[acceptance] FAIL   {fail_old} -> {fail_new}    (no new FAIL)")

    reasons = []

    if ok_new < ok_old:
        reasons.append(f"gating OK count dropped {ok_old} -> {ok_new}")

    if xf_new > xf_old:
        reasons.append(f"XFAIL count grew {xf_old} -> {xf_new}")

    new_fails = [c for c in common if sn[c] == "FAIL" and so[c] != "FAIL"]

    if new_fails:
        reasons.append(f"new FAIL appeared: {', '.join(new_fails)}")

    # Each case that is XFAIL in both must not lose matched nodes (PROMPTS.md:
    # the parity `matched` must not decrease).
    for case in common:
        if so[case] == "XFAIL" and sn[case] == "XFAIL" and case in mo and case in mn:
            if mn[case] < mo[case]:
                reasons.append(f"{case} parity matched dropped {mo[case]} -> {mn[case]}")

    return (not reasons), reasons


def main():
    if len(sys.argv) != 3:
        log("usage: acceptance <OLD_REPO> <NEW_REPO>")

        return 2

    old_repo = os.path.abspath(sys.argv[1])
    new_repo = os.path.abspath(sys.argv[2])
    work = tempfile.mkdtemp(prefix="acceptance-", dir=os.environ.get("TMPDIR") or None)

    log(f"[acceptance] OLD  = {old_repo}")
    log(f"[acceptance] NEW  = {new_repo}")
    log(f"[acceptance] work = {work}")

    try:
        # Run OLD and NEW concurrently in two threads — the sg7 generation
        # dominates wall time, so parallelizing roughly halves it. Each run
        # streams its own [OLD]/[NEW]-prefixed output (log() is line-atomic) into
        # its own fresh subdir (no cross-run staleness) and frees that subdir's
        # multi-GB graph dumps as soon as its text output is captured. Peak disk
        # is both repos at once — accepted for the wall-time win; the watchdog
        # timeout fires per run independently.
        results = {}

        def worker(label, repo, out):
            # Any failure here MUST become a recorded RunResult (logged to stdout),
            # never an uncaught thread exception lost to stderr — otherwise main's
            # results[label] lookup raises and the merger sees only the header.
            try:
                res = run_validate(label, repo, out)
            except Exception:
                tb = traceback.format_exc()
                log(f"[acceptance] {label}: worker crashed:\n{tb}")
                res = RunResult(label, False, error=f"worker crashed: {tb.strip().splitlines()[-1]}")
            finally:
                shutil.rmtree(out, ignore_errors=True)
            results[label] = res

        threads = [
            threading.Thread(target=worker, args=("OLD", old_repo, os.path.join(work, "old"))),
            threading.Thread(target=worker, args=("NEW", new_repo, os.path.join(work, "new"))),
        ]

        for t in threads:
            t.start()

        for t in threads:
            t.join()

        # Defensive: a worker that somehow never recorded a result is itself a
        # diagnostic, not a KeyError.
        res_old = results.get("OLD", RunResult("OLD", False, error="no result recorded (worker did not run)"))
        res_new = results.get("NEW", RunResult("NEW", False, error="no result recorded (worker did not run)"))

        so, mo, oo = parse(res_old.output)
        sn, mn, on = parse(res_new.output)

        # A side is comparable only if it ran cleanly and produced case results.
        # Any infrastructure failure (launch error, timeout, crash, empty output,
        # missing result) rejects with an actionable, stdout-logged reason that
        # names the side — so the merger log distinguishes it from a candidate
        # rejection.
        unusable = []
        for res, status in ((res_old, so), (res_new, sn)):
            reason = usability_reason(res, status)
            if reason:
                unusable.append((res.label, reason, res.output))

        if unusable:
            log("")
            log("[acceptance] VERDICT: REJECT (validate.py run did not yield usable results)")
            for label, reason, output in unusable:
                log(f"  - {label}: {reason}")
                log(f"    last output:\n{_tail(output)}")

            return 1

        accept, reasons = decide(so, mo, oo, sn, mn, on)

        log("")

        if accept:
            log("[acceptance] VERDICT: ACCEPT — NEW is mergeable over OLD")

            return 0

        log("[acceptance] VERDICT: REJECT")

        for r in reasons:
            log(f"  - {r}")

        return 1
    finally:
        shutil.rmtree(work, ignore_errors=True)


if __name__ == "__main__":
    raise SystemExit(main())
